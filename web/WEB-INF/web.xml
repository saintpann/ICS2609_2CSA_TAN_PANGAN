<?xml version="1.0" encoding="UTF-8"?>
<web-app version="2.5" xmlns="http://java.sun.com/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd">
    <context-param>
        <param-name>header</param-name>
        <param-value>ICS2609/2CSA/Pangan - Tan</param-value>
    </context-param>
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>Controllers.LoginServlet</servlet-class>
        <init-param>
            <param-name>jdbcClassName</param-name>
            <param-value>org.apache.derby.jdbc.ClientDriver</param-value>
        </init-param>
        <init-param>
            <param-name>dbUserName</param-name>
            <param-value>app</param-value>
            <!--<param-value>root</param-value>-->
        </init-param>
        <init-param>
            <param-name>dbPassword</param-name>
            <param-value>app</param-value>
        </init-param>
        <init-param>
            <param-name>jdbcDriverURL</param-name>
            <param-value>jdbc:derby</param-value>
        </init-param>
        <init-param>
            <param-name>dbHostName</param-name>
            <param-value>localhost</param-value>
        </init-param>
        <init-param>
            <param-name>dbPort</param-name>
            <param-value>1527</param-value>
        </init-param>
        <init-param>
            <param-name>databaseName</param-name>
            <param-value>LoginDB</param-value>
        </init-param>
    </servlet>
    <servlet>
        <servlet-name>headerFooter</servlet-name>
        <servlet-class>Controllers.HeaderFooter</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>headerFooter</servlet-name>
        <url-pattern>/headerFooter</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            5
        </session-timeout>
    </session-config>
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
    <error-page>
        <exception-type>Objects.NoUsernameFoundException</exception-type>
        <location>/WEB-INF/jsps/errorpages/error_1.jsp</location>
    </error-page>
    <error-page>
        <exception-type>Objects.IncorrectPassException</exception-type>
        <location>/WEB-INF/jsps/errorpages/error_2.jsp</location>
    </error-page>
    <error-page>
        <exception-type>Objects.IncorrectUserPassException</exception-type>
        <location>/WEB-INF/jsps/errorpages/error_3.jsp</location>
    </error-page>
    <error-page>
        <exception-type>Objects.NullValueException</exception-type>
        <location>/WEB-INF/jsps/errorpages/noLoginCredentials.jsp</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/jsps/errorpages/error_4.jsp</location>
    </error-page>
</web-app>
