<?xml version="1.0" encoding="UTF-8"?>
<web-app version="2.5" xmlns="http://java.sun.com/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd">
    <context-param>
        <param-name>header</param-name>
        <param-value>ICS2609/2CSA/Pangan - Tan</param-value>
    </context-param>
    <context-param>
        <param-name>jdbcClassName</param-name>
        <param-value>org.apache.derby.jdbc.ClientDriver</param-value>
    </context-param>
    <context-param>
        <param-name>dbUserName</param-name>
        <param-value>app</param-value>
    </context-param>
    <context-param>
        <param-name>dbPassword</param-name>
        <param-value>app</param-value>
    </context-param>
    <context-param>
        <param-name>jdbcDriverURL</param-name>
        <param-value>jdbc:derby</param-value>
    </context-param>
    <context-param>
        <param-name>dbHostName</param-name>
        <param-value>localhost</param-value>
    </context-param>
    <context-param>
        <param-name>dbPort</param-name>
        <param-value>1527</param-value>
    </context-param>
    <context-param>
        <param-name>databaseName</param-name>
        <param-value>LoginDB</param-value>
    </context-param>
    
    
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>controller.LoginServlet</servlet-class>
        <init-param>
            <param-name>jdbcClassName</param-name>
            <param-value>org.apache.derby.jdbc.ClientDriver</param-value>
        </init-param>
        <init-param>
            <param-name>dbUserName</param-name>
            <param-value>app</param-value>
            <!--<param-value>root</param-value>-->
        </init-param>
        <init-param>
            <param-name>dbPassword</param-name>
            <param-value>app</param-value>
        </init-param>
        <init-param>
            <param-name>jdbcDriverURL</param-name>
            <param-value>jdbc:derby</param-value>
        </init-param>
        <init-param>
            <param-name>dbHostName</param-name>
            <param-value>localhost</param-value>
        </init-param>
        <init-param>
            <param-name>dbPort</param-name>
            <param-value>1527</param-value>
        </init-param>
        <init-param>
            <param-name>databaseName</param-name>
            <param-value>LoginDB</param-value>
        </init-param>
    </servlet>
     
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/logic</url-pattern>
    </servlet-mapping>
    
    <listener>
        <listener-class>
            listener.HeaderFooter
        </listener-class>
    </listener>
    
    <servlet>
        <servlet-name>HeaderFooter</servlet-name>
        <servlet-class>listener.HeaderFooter</servlet-class>
    </servlet>
    
    <servlet>
        <servlet-name>SuccessServlet</servlet-name>
        <servlet-class>controller.SuccessServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SuccessServlet</servlet-name>
        <url-pattern>/success</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>CRUDServlet</servlet-name>
        <servlet-class>controller.CRUDServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CRUDServlet</servlet-name>
        <url-pattern>/crud</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>AddServlet</servlet-name>
        <servlet-class>controller.AddServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddServlet</servlet-name>
        <url-pattern>/add</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>UpdateServlet</servlet-name>
        <servlet-class>controller.UpdateServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateServlet</servlet-name>
        <url-pattern>/update</url-pattern>
    </servlet-mapping>
    
    <servlet>
        <servlet-name>HomeServlet</servlet-name>
        <servlet-class>controller.HomeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HomeServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    
    
    <session-config>
        <session-timeout>
            5
        </session-timeout>
    </session-config>
    <welcome-file-list>
        <welcome-file>login</welcome-file>
    </welcome-file-list>
    
    <error-page>
        <exception-type>miscs.NoUsernameFoundException</exception-type>
        <location>/WEB-INF/jsps/errorpages/error_1.jsp</location>
    </error-page>
    <error-page>
        <exception-type>miscs.IncorrectPassException</exception-type>
        <location>/WEB-INF/jsps/errorpages/error_2.jsp</location>
    </error-page>
    <error-page>
        <exception-type>miscs.IncorrectUserPassException</exception-type>
        <location>/WEB-INF/jsps/errorpages/error_3.jsp</location>
    </error-page>
    <error-page>
        <exception-type>miscs.AuthenticationException</exception-type>
        <location>/WEB-INF/jsps/errorpages/error_session.jsp</location>
    </error-page>
    <error-page>
        <exception-type>miscs.NullValueException</exception-type>
        <location>/WEB-INF/jsps/errorpages/noLoginCredentials.jsp</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/jsps/errorpages/error_4.jsp</location>
    </error-page>
    <error-page>
        <error-code>405</error-code>
        <location>/WEB-INF/jsps/errorpages/error_5.jsp</location>
    </error-page>
</web-app>